{
  "name": "taskflow",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.8.0",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "dev": "vite",
    "typegen": "react-router-next typegen",
    "build": "pnpm run typegen && tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "pnpm run typegen && tsc -b --noEmit",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "mock:init": "msw init public --save"
  },
  "dependencies": {
    "@apollo/client": "^4.2.3",
    "@evolonix/react-router-next": "^3.6.1",
    "@jasonruesch/react": "^0.3.5",
    "@jasonruesch/tokens": "^0.1.1",
    "@tanstack/react-query": "^5.101.0",
    "graphql": "^17.0.1",
    "lucide-react": "^1.21.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router": "^8.0.1",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@faker-js/faker": "^10.5.0",
    "@mswjs/data": "^0.16.2",
    "@playwright/test": "^1.61.0",
    "@tailwindcss/vite": "^4.3.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^26.0.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "@vitest/coverage-v8": "^4.1.9",
    "axe-core": "^4.12.1",
    "eslint": "^10.5.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.6.0",
    "jsdom": "^29.1.1",
    "msw": "^2.14.6",
    "tailwindcss": "^4.3.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.1",
    "vite": "^8.0.16",
    "vitest": "^4.1.9",
    "vitest-axe": "^0.1.0"
  },
  "msw": {
    "workerDirectory": [
      "public"
    ]
  }
}
